{
  "manifest_version": 2,
  "description": "Professional per-tab audio mixing console for Firefox",
  "browser_specific_settings": {
    "gecko": {
      "id": "audio-console@samanthahldr",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": ["tabs", "tabGroups", "storage", "<all_urls>"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "sidebar_action": {
    "default_title": "Audio Console",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "48": "icons/icon.svg"
    }
  },
  "web_accessible_resources": ["worklets/*.js"]
}
